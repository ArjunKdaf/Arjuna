+
+#window-modal-dialog {
+  overflow: visible;
+  padding: 0;
+  /* Override default <html:dialog> styles */
+  border-width: 0;
+  background-color: transparent;
+  /* This makes the dialog top-aligned by default (the dialog box will move via
