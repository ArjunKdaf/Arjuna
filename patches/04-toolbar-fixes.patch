+    .split-view-panel[column="0"] {
+      order: 0;
+      margin-inline-end: 0;
+    }
+
+    .split-view-splitter {
+      order: 1;
+      flex: none;
+      -moz-user-focus: normal;
+
+      &:focus-visible {
+        outline: auto;
+      }
+    }
+
+    .split-view-panel[column="1"] {
+      order: 2;
+      margin-inline-start: 0;
+    }
