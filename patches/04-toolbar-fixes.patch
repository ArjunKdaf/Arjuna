+        : this.#defaultList;
+    }
+    return this.#target;
+  }
+
+  /**
+   * Private methods start here.
+   */
+
+  /**
+   * Handle overflow in the toolbar by moving items to the overflow menu.
+   */
+  async #onOverflow() {
+    if (!this.#enabled) {
+      return;
+    }
