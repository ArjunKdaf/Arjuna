+      let targetID = this.#toolbar.getAttribute("addon-webext-overflowtarget");
+      if (!targetID) {
+        throw new Error(
+          "addon-webext-overflowtarget was not defined on the " +
+            `overflowable toolbar with id: ${this.#toolbar.id}`
+        );
+      }
