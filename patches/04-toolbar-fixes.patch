+    if (checkOverflowHandle == this.#checkOverflowHandle) {
+      this.#checkOverflowHandle = null;
+    }
+  }
+
+  /**
+   * Makes the OverflowableToolbar inert and moves all overflowable items back
+   * into the customization target of the toolbar.
+   */
+  #disable() {
