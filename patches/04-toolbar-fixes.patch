+      CustomizableUIInternal.notifyListeners(
+        "onWidgetUnderflow",
+        child,
+        this.#target
+      );
+    }
+
+    win.UpdateUrlbarSearchSplitterState();
+
+    let defaultListItems = Array.from(this.#defaultList.children);
+    if (
+      defaultListItems.every(
+        item =>
+          CustomizableUI.isSpecialWidget(item.id) ||
