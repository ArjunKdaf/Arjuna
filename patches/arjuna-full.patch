+  height: 100%;
+  inset-inline-start: 0;
+  pointer-events: none;
+  position: absolute;
+  inset-block-start: 0;
+  width: 100%;
+  z-index: 100;
+}
+
+@keyframes fadeIn {
+  from {
+    opacity: 0;
+  }
+  to {
+    opacity: 1;
+  }
+}
+.show-on-init {
+  opacity: 0;
+  transition: opacity 0.2s ease-in;
+}
+.show-on-init.on {
+  animation: fadeIn 0.2s;
+  opacity: 1;
+}
