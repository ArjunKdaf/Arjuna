+.actions {
+  border-block-start: 1px solid var(--border-color);
+  display: flex;
+  flex-direction: row;
+  flex-wrap: wrap;
+  justify-content: flex-start;
+  margin: 0;
+  padding: var(--space-large) var(--space-xlarge) 0;
