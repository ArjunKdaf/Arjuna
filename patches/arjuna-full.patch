+.button,
+.actions button {
+  background-color: var(--newtab-button-secondary-color);
+  border: 1px solid var(--border-color);
+  border-radius: var(--border-radius-small);
+  color: inherit;
+  cursor: pointer;
+  margin-block-end: var(--space-large);
+  padding: var(--space-small) var(--space-xxlarge);
+  white-space: nowrap;
