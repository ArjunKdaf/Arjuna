+    let doc = weakDoc.get();
+    if (doc) {
+      // Store locally so we can cache the result:
+      aNode = CustomizableUIInternal.findXULWidgetInWindow(
+        aWidgetId,
+        doc.defaultView
+      );
+      return aNode;
+    }
